<?xml version="1.0" encoding="UTF-8"?>
<plan id="test-requirements-checklist" title="Requirements Checklist Field Fix Test" agent="qa-principal">
  <node
    id="node1"
    type="task"
    title="Required and Optional Fields"
    description="Node with mix of required and optional fields to test checklist display">
    <dynamic_field
      id="req_field_1"
      type="string"
      name="project_name"
      title="Project Name"
      description="Required field - must be filled"
      required="true"
    />
    <dynamic_field
      id="opt_field_1"
      type="string"
      name="project_description"
      title="Project Description"
      description="Optional field - can be left empty"
      required="false"
    />
    <dynamic_field
      id="req_field_2"
      type="select"
      name="environment"
      title="Environment"
      description="Required select field"
      options="Development,Staging,Production"
      required="true"
    />
  </node>

  <node
    id="node2"
    type="task"
    title="All Optional Fields"
    description="Node with only optional fields to test progress calculation">
    <dynamic_field
      id="opt_field_2"
      type="string"
      name="additional_notes"
      title="Additional Notes"
      description="Optional notes field"
      required="false"
    />
    <dynamic_field
      id="opt_field_3"
      type="boolean"
      name="enable_logging"
      title="Enable Logging"
      description="Optional boolean field"
      required="false"
    />
  </node>

  <node
    id="node3"
    type="task"
    title="Default Values Test"
    description="Node with fields that have default values">
    <dynamic_field
      id="default_field_1"
      type="string"
      name="default_path"
      title="Default Path"
      description="Field with default value"
      default="/usr/local"
      required="true"
    />
    <dynamic_field
      id="default_field_2"
      type="boolean"
      name="auto_deploy"
      title="Auto Deploy"
      description="Optional boolean with default"
      default="true"
      required="false"
    />
  </node>

  <node
    id="node4"
    type="task"
    title="All Required Fields"
    description="Node with only required fields to test approval blocking">
    <dynamic_field
      id="req_field_3"
      type="string"
      name="api_key"
      title="API Key"
      description="Required API key"
      required="true"
    />
    <dynamic_field
      id="req_field_4"
      type="number"
      name="timeout"
      title="Timeout (seconds)"
      description="Required timeout value"
      required="true"
    />
  </node>

  <node
    id="node5"
    type="task"
    title="Edge Case: Empty Node"
    description="Node with no fields - should not appear in checklist">
  </node>

  <edge from="node1" to="node2" />
  <edge from="node2" to="node3" />
  <edge from="node3" to="node4" />
  <edge from="node4" to="node5" />
</plan>
