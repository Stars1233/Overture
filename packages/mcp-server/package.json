{
  "name": "@overture/mcp-server",
  "version": "0.1.0",
  "description": "Overture MCP Server - Visual agent plan execution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "overture": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "sax": "^1.3.0",
    "open": "^10.0.0",
    "chalk": "^5.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/sax": "^1.2.7",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "tsup": "^8.0.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  },
  "files": [
    "dist",
    "ui-dist"
  ],
  "keywords": [
    "mcp",
    "ai",
    "agent",
    "visualization"
  ],
  "author": "Sixth",
  "license": "MIT"
}
